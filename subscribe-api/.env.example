PORT=8787
NODE_ENV=development

# In production set this to your public newsletter domain, for example:
# https://newsletter.example.com
LISTMONK_URL=http://localhost:9000

# Comma-separated public list UUIDs from Listmonk.
# Create a public list in Listmonk and copy its UUID here.
LISTMONK_LIST_UUIDS=replace-with-list-uuid

# true lets you test the API flow without a running Listmonk instance.
LISTMONK_DRY_RUN=true

# Comma-separated allowed origins. Use your website domain in production.
# Example: https://www.example.com,https://example.com
ALLOWED_ORIGINS=http://localhost:5173,https://www.example.com,https://example.com

# Basic anti-spam settings.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=12

# Consent log location. This stores an append-only JSONL audit trail.
CONSENT_LOG_PATH=./data/consent-log.jsonl
