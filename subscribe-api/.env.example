PORT=8787
NODE_ENV=development

# In production set this to the public newsletter domain, for example:
# https://newsletter.ommelb.com.au
LISTMONK_URL=http://localhost:9000

# Comma-separated public list UUIDs from Listmonk.
# Create a public list in Listmonk and copy its UUID here.
LISTMONK_LIST_UUIDS=replace-with-list-uuid

# true lets you test the Wix/API flow without a running Listmonk instance.
LISTMONK_DRY_RUN=true

# Comma-separated allowed origins. Use the Wix domain in production.
# Example: https://www.ommelb.com.au,https://ommelb.com.au
ALLOWED_ORIGINS=http://localhost:5173,https://www.ommelb.com.au,https://ommelb.com.au

# Basic anti-spam settings.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=12

# Consent log location. This stores an append-only JSONL audit trail.
CONSENT_LOG_PATH=./data/consent-log.jsonl
